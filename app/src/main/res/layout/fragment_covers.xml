<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🎵 AI 翻唱" android:textSize="22sp" android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="选择歌曲 → 选择翻唱风格 → AI 用新声音重新演绎"
        android:textSize="13sp" android:textColor="#888888" android:layout_marginBottom="16dp" />

    <!-- 选择原唱歌曲 -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🎤 原唱歌曲" android:textSize="16sp" android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <Button android:id="@+id/btn_select_song"
        android:layout_width="match_parent" android:layout_height="45dp"
        android:text="📂 选择歌曲音频文件" android:backgroundTint="#9C27B0"
        android:layout_marginBottom="4dp" />

    <TextView android:id="@+id/tv_song_file"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="未选择文件" android:textSize="12sp" android:textColor="#999999"
        android:layout_marginBottom="16dp" />

    <!-- 翻唱风格选择 -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🎨 翻唱风格" android:textSize="16sp" android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="选择预设风格，或在下方自定义描述（至少10字）"
        android:textSize="12sp" android:textColor="#888888" android:layout_marginBottom="6dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_styles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" />

    <EditText android:id="@+id/et_song_desc"
        android:layout_width="match_parent" android:layout_height="80dp"
        android:hint="自定义风格描述（中文或英文均可）"
        android:inputType="textMultiLine" android:textSize="13sp"
        android:gravity="top|start" android:padding="10dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="20dp" />

    <!-- 生成按钮 -->
    <Button android:id="@+id/btn_generate"
        android:layout_width="match_parent" android:layout_height="50dp"
        android:text="🎵 开始翻唱" android:backgroundTint="#FF6584"
        android:layout_marginBottom="12dp" />

    <ProgressBar android:id="@+id/progress_bar"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:visibility="gone" />

    <TextView android:id="@+id/tv_status"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="14sp" android:layout_marginTop="8dp" />

    <!-- 播放区域 -->
    <LinearLayout android:id="@+id/layout_playback"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center_horizontal"
        android:padding="16dp" android:background="#FFF5F7"
        android:layout_marginTop="12dp" android:visibility="gone">

        <Button android:id="@+id/btn_play"
            android:layout_width="200dp" android:layout_height="48dp"
            android:text="▶️ 播放翻唱" android:backgroundTint="#FF6584" />
    </LinearLayout>

</LinearLayout>
</ScrollView>
