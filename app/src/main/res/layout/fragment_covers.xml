<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 顶部标题 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🎵 AI 翻唱" android:textSize="22sp" android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Tab 切换 -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_engine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:singleSelection="true"
            app:selectionRequired="true">
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_engine_minimax"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎵 MiniMax API"
                android:checkable="true"
                style="@style/Widget.MaterialComponents.Chip.Choice" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_engine_memotune"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🆓 MemoTune 免费"
                android:checkable="true"
                style="@style/Widget.MaterialComponents.Chip.Choice" />
        </com.google.android.material.chip.ChipGroup>
    </LinearLayout>

    <!-- MiniMax 原有内容区域 -->
    <ScrollView android:id="@+id/layout_minimax"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingBottom="16dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="选择歌曲 → 选择翻唱风格 → AI 用新声音重新演绎"
        android:textSize="13sp" android:textColor="#888888" android:layout_marginBottom="16dp" />

    <!-- 选择原唱歌曲 -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🎤 原唱歌曲" android:textSize="16sp" android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <Button android:id="@+id/btn_select_song"
        android:layout_width="match_parent" android:layout_height="45dp"
        android:text="📂 选择歌曲音频文件" android:backgroundTint="#9C27B0"
        android:layout_marginBottom="4dp" />

    <TextView android:id="@+id/tv_song_file"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="未选择文件" android:textSize="12sp" android:textColor="#999999"
        android:layout_marginBottom="16dp" />

    <!-- 模型选择 -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🔧 模型选择" android:textSize="16sp" android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="4dp">
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_free_model"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🆓 免费版" android:checkable="true"
            android:layout_marginEnd="8dp" style="@style/Widget.MaterialComponents.Chip.Choice" />
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_paid_model"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="💎 付费版（风格控制强）" android:checkable="true"
            style="@style/Widget.MaterialComponents.Chip.Choice" />
    </LinearLayout>

    <TextView android:id="@+id/tv_model_hint"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="💡 免费模型，风格控制较弱但完全免费"
        android:textSize="12sp" android:textColor="#888888" android:layout_marginBottom="16dp" />

    <!-- 翻唱风格选择 -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🎨 翻唱风格" android:textSize="16sp" android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="选择预设风格，或在下方自定义描述（至少10字）"
        android:textSize="12sp" android:textColor="#888888" android:layout_marginBottom="6dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_styles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" />

    <EditText android:id="@+id/et_song_desc"
        android:layout_width="match_parent" android:layout_height="80dp"
        android:hint="自定义风格描述（中文或英文均可）"
        android:inputType="textMultiLine" android:textSize="13sp"
        android:gravity="top|start" android:padding="10dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="20dp" />

    <!-- 生成按钮 -->
    <Button android:id="@+id/btn_generate"
        android:layout_width="match_parent" android:layout_height="50dp"
        android:text="🎵 开始翻唱" android:backgroundTint="#FF6584"
        android:layout_marginBottom="12dp" />

    <ProgressBar android:id="@+id/progress_bar"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:visibility="gone" />

    <TextView android:id="@+id/tv_status"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="14sp" android:layout_marginTop="8dp" />

    <!-- ===== 歌词显示 ===== -->
    <LinearLayout android:id="@+id/layout_lyrics"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center_horizontal"
        android:padding="16dp" android:background="#F0F4FF"
        android:layout_marginTop="16dp" android:visibility="gone">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📝 歌词" android:textSize="12sp" android:textColor="#888888"
            android:layout_marginBottom="6dp" />

        <TextView android:id="@+id/tv_lyrics_line1"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="16sp" android:textStyle="bold" android:textColor="#333333"
            android:gravity="center" android:layout_marginBottom="4dp"
            android:text="" />

        <TextView android:id="@+id/tv_lyrics_line2"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="#666666"
            android:gravity="center"
            android:text="" />
    </LinearLayout>

    <!-- ===== 播放区域（进度条+时间+控制按钮+下载） ===== -->
    <LinearLayout android:id="@+id/layout_playback"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp"
        android:background="#FFF5F7" android:layout_marginTop="12dp"
        android:visibility="gone">

        <!-- 进度条 + 时间 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:id="@+id/tv_time_current"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0:00" android:textSize="12sp" android:textColor="#888888"
                android:minWidth="36dp" />
            <SeekBar android:id="@+id/seek_bar_playback"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/tv_time_total"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0:00" android:textSize="12sp" android:textColor="#888888"
                android:minWidth="36dp" />
        </LinearLayout>

        <!-- 控制按钮 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btn_stop"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:text="⏹ 停止"
                android:backgroundTint="#9E9E9E" android:layout_marginEnd="8dp" />

            <Button android:id="@+id/btn_play"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:text="▶️ 播放"
                android:backgroundTint="#FF6584" android:layout_marginEnd="8dp" />

            <Button android:id="@+id/btn_download"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:text="📥 下载"
                android:backgroundTint="#4CAF50" />
        </LinearLayout>
    </LinearLayout>

    </LinearLayout>
    </ScrollView>

    <!-- MemoTune WebView 区域 -->
    <FrameLayout android:id="@+id/layout_memotune"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <ProgressBar android:id="@+id/progress_webview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <WebView android:id="@+id/webview_memotune"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

</LinearLayout>
