<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher_purple"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_purple"
        android:supportsRtl="true"
        android:theme="@style/Theme.AIVoice"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <!-- 主 Activity（紫色默认图标） -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.AIVoice">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 蓝色图标 alias -->
        <activity-alias
            android:name=".MainActivityAliasBlue"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_launcher_blue"
            android:roundIcon="@drawable/ic_launcher_blue"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 粉色图标 alias -->
        <activity-alias
            android:name=".MainActivityAliasPink"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_launcher_pink"
            android:roundIcon="@drawable/ic_launcher_pink"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 绿色图标 alias -->
        <activity-alias
            android:name=".MainActivityAliasGreen"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_launcher_green"
            android:roundIcon="@drawable/ic_launcher_green"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 橙色图标 alias -->
        <activity-alias
            android:name=".MainActivityAliasOrange"
            android:enabled="false"
            android:exported="true"
            android:icon="@drawable/ic_launcher_orange"
            android:roundIcon="@drawable/ic_launcher_orange"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
